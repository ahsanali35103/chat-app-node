      "name": "Auth",
      "item": [
        {
          "name": "Sign-Up",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "// Test: Status code\r",
                  "pm.test(\"Status code is 200 for successful signup\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Test: Only check user data if signup succeeded\r",
                  "pm.test(\"Signup response has success structure\", function () {\r",
                  "    pm.expect(jsonData).to.have.property(\"success\", true);\r",
                  "    pm.expect(jsonData).to.have.property(\"message\");\r",
                  "\r",
                  "    if (jsonData.data && jsonData.data.user) {\r",
                  "        pm.expect(jsonData.data.user).to.have.property(\"email\");\r",
                  "        pm.expect(jsonData.data.user).to.have.property(\"id\");\r",
                  "        console.log(\"User email:\", jsonData.data.user.email);\r",
                  "    } else {\r",
                  "        console.log(\"User object not returned. Signup may have failed.\");\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text",
                "disabled": true
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"John Doe\",\r\n  \"email\": \"john@example.com\",\r\n  \"password\": \"password123\",\r\n  \"confirmPassword\": \"password123\"\r\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/signup",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "auth",
                "signup"
              ]
            }
          },
          "response": []
        },
